    {"type": "text", "x": 0, "y": 170, "text": "Anisotropic Solar Cell Surface", "color": "primary", "font_size": 13},
    {"type": "text", "x": 0, "y": 190, "text": "(grid structure → direction-dependent reflectance)", "color": "light_text", "font_size": 11},

    {"type": "text", "x": -180, "y": -30, "text": "Incident", "color": "primary", "font_size": 12},
    {"type": "text", "x": 180, "y": -10, "text": "Reflected", "color": "secondary", "font_size": 12},

    {"type": "text", "x": 500, "y": 110, "text": "Polar BRDF Plot", "color": "stroke", "font_size": 13},
    {"type": "text", "x": 500, "y": 395, "text": "Viewing Angle θ_r", "color": "light_text", "font_size": 11},
    {"type": "text", "x": 370, "y": 260, "text": "0°", "color": "light_text", "font_size": 10},
    {"type": "text", "x": 640, "y": 260, "text": "180°", "color": "light_text", "font_size": 10},

    {"type": "text", "x": 660, "y": 170, "text": "Γ-axis scan", "color": "primary", "font_size": 11},
    {"type": "text", "x": 660, "y": 190, "text": "M-axis scan", "color": "secondary", "font_size": 11},
    {"type": "text", "x": 660, "y": 210, "text": "Out-of-plane", "color": "accent", "font_size": 11},

    {"type": "text", "x": -350, "y": 280, "text": "Key Physics:", "color": "stroke", "font_size": 13},
    {"type": "text", "x": -350, "y": 300, "text": "BRDF = dL_r / (L_i · cos θ_i · dω_r)", "color": "primary", "font_size": 12},
    {"type": "text", "x": -350, "y": 320, "text": "Anisotropy: f_r(θ_i, θ_r, φ) ≠ f_r(θ_i, θ_r, 0)", "color": "secondary", "font_size": 12},
    {"type": "text", "x": -350, "y": 340, "text": "Grid-aligned surface →", "color": "light_text", "font_size": 11},
    {"type": "text", "x": -350, "y": 358, "text": "  reflectance peaks shift with φ", "color": "light_text", "font_size": 11},
    {"type": "text", "x": -350, "y": 385, "text": "In-plane: specular + diffuse lobe", "color": "stroke", "font_size": 11},
    {"type": "text", "x": -350, "y": 403, "text": "Out-of-plane: reveals anisotropic", "color": "stroke", "font_size": 11},
    {"type": "text", "x": -350, "y": 421, "text": "  scattering from surface periodicity", "color": "stroke", "font_size": 11}
