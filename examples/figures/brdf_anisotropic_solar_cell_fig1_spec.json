{
  "title": "BRDF Measurement Geometry for Anisotropic Satellite Solar Cells",
  "description": "Illustrates the bidirectional reflectance distribution function (BRDF) measurement setup, showing how reflectance from an anisotropic solar cell surface depends on incidence angle (θ_i), viewing angle (θ_r), and azimuthal angle (φ). Includes the in-plane and out-of-plane measurement geometry, the anisotropic surface structure, and a polar BRDF plot showing angular reflectance variation.",
  "canvas": {"width": 1400, "height": 900},
  "style": {
    "font_size": 14,
    "font_family": "Arial, Helvetica, sans-serif",
    "colors": {
      "primary": "#0072B2",
      "secondary": "#D55E00",
      "accent": "#CC79A7",
      "stroke": "#333333",
      "fill": "#E8E8E8",
      "text": "#333333",
      "light_text": "#666666"
    }
  },
  "elements": [
    {"id": "sample", "type": "box", "x": 0, "y": 100, "w": 300, "h": 80, "color": "primary", "fill_opacity": 0.15, "text": ""},
    {"id": "surface_grid", "type": "line", "x1": -120, "y1": 100, "x2": 120, "y2": 100, "color": "stroke", "stroke_dash": "4,2"},
    {"id": "h1", "type": "line", "x1": -100, "y1": 105, "x2": -100, "y2": 140, "color": "stroke"},
    {"id": "h2", "type": "line", "x1": -60, "y1": 105, "x2": -60, "y2": 140, "color": "stroke"},
