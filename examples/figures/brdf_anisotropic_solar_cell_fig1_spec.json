    {"id": "h4", "type": "line", "x1": 20, "y1": 105, "x2": 20, "y2": 140, "color": "stroke"},
    {"id": "h5", "type": "line", "x1": 60, "y1": 105, "x2": 60, "y2": 140, "color": "stroke"},
    {"id": "h6", "type": "line", "x1": 100, "y1": 105, "x2": 100, "y2": 140, "color": "stroke"},

    {"id": "normal", "type": "line", "x1": 0, "y1": 100, "x2": 0, "y2": -80, "color": "stroke", "stroke_dash": "5,3"},
    {"id": "incident_ray", "type": "line", "x1": -250, "y1": -150, "x2": 0, "y2": 100, "color": "primary"},
    {"id": "reflected_ray", "type": "line", "x1": 0, "y1": 100, "x2": 280, "y2": -120, "color": "secondary"},
